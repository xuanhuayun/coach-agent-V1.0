# Copy to .env.local (never commit .env.local)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local dev only: skip Magic Link + login (never set in production / Vercel)
# 1) In Supabase: Authentication → Users → copy one user’s UUID (or create a user once).
# 2) Project Settings → API → copy service_role key (secret).
# Local machine only (Vercel sets VERCEL=1 so bypass won't run there).
# Must use NEXT_PUBLIC_ so Middleware (Edge) can see the flag:
# NEXT_PUBLIC_COACH_AGENT_DEV_SKIP=1
# COACH_AGENT_DEV_USER_ID=
# SUPABASE_SERVICE_ROLE_KEY=
# (optional duplicate flag for scripts)
# COACH_AGENT_DEV_SKIP_AUTH=1
